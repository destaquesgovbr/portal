# Typesense Configuration
# For local development with govbrnews-typesense container:
# The container fetches the actual API key from GCP Secret Manager on startup
# Check container logs for the actual API key: docker logs govbrnews-typesense | grep "API Key:"

NEXT_PUBLIC_TYPESENSE_HOST=localhost
NEXT_PUBLIC_TYPESENSE_SEARCH_ONLY_API_KEY=your-api-key-here

# Site Configuration (optional - will auto-detect from Cloud Run if not set)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Microsoft Clarity - Analytics (heatmaps and session recording)
# Get your project ID from https://clarity.microsoft.com
# Leave empty to disable analytics
NEXT_PUBLIC_CLARITY_PROJECT_ID=clarity-project-id

# GrowthBook - A/B Testing and Feature Flags
# Get your credentials from https://app.growthbook.io or your self-hosted instance
# Leave empty to disable A/B testing (features will use default values)
NEXT_PUBLIC_GROWTHBOOK_API_HOST=https://cdn.growthbook.io
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=sdk-xxxxx

# Umami Analytics - Privacy-first analytics (pageviews and events)
# Self-host Umami (https://umami.is) or use Umami Cloud
# Leave empty to disable Umami analytics
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://your-umami-instance.com/script.js

# Autenticacao (NextAuth.js)
# Gerar com: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (desenvolvimento)
# Criar credenciais em: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Gov.Br (producao)
# AUTH_GOVBR_ID=
# AUTH_GOVBR_SECRET=
# AUTH_GOVBR_ISSUER=https://sso.acesso.gov.br

# Admin Access Control
# Comma-separated list of email addresses that have admin access
# Admins can bypass invite gate and access /admin routes
ADMIN_EMAILS=
